def parse_prometheus_metrics(text: str) -> Dict[str, float]:
    metrics: Dict[str, float] = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        try:
            metric_part, value_part = line.rsplit(" ", 1)
            metric_name = metric_part.split("{", 1)[0].strip()
            value = float(value_part.strip())
            metrics[metric_name] = metrics.get(metric_name, 0.0) + value
        except Exception:
            continue
    return metrics


def get_metric(metrics: Dict[str, float], names: List[str], default=0.0):
    for name in names:
        if name in metrics:
            return metrics[name]
    return default


def get_vllm_metrics_snapshot(metrics_url: str) -> Dict[str, float]:
    try:
        response = requests.get(metrics_url, timeout=5)
        if response.status_code != 200:
            return {}
        metrics = parse_prometheus_metrics(response.text)
        prefix_queries = get_metric(metrics, ["vllm:prefix_cache_queries_total", "vllm:prefix_cache_queries"], 0.0)
        prefix_hits = get_metric(metrics, ["vllm:prefix_cache_hits_total", "vllm:prefix_cache_hits"], 0.0)
        kv_cache_usage = get_metric(metrics, ["vllm:kv_cache_usage_perc", "vllm:gpu_cache_usage_perc"], 0.0)
        running_requests = get_metric(metrics, ["vllm:num_requests_running"], 0.0)
        waiting_requests = get_metric(metrics, ["vllm:num_requests_waiting"], 0.0)
        prefix_misses = max(prefix_queries - prefix_hits, 0.0)
        return {
            "prefix_queries": prefix_queries,
            "prefix_hits": prefix_hits,
            "prefix_misses": prefix_misses,
            "kv_cache_usage": kv_cache_usage,
            "running_requests": running_requests,
            "waiting_requests": waiting_requests,
        }
    except Exception:
        return {}


def build_vllm_metrics_delta(before: Dict, after: Dict) -> Dict:
    prefix_queries_delta = after.get("prefix_queries", 0.0) - before.get("prefix_queries", 0.0)
    prefix_hits_delta = after.get("prefix_hits", 0.0) - before.get("prefix_hits", 0.0)
    prefix_misses_delta = after.get("prefix_misses", 0.0) - before.get("prefix_misses", 0.0)
    if prefix_misses_delta < 0:
        prefix_misses_delta = ""
    if prefix_queries_delta > 0:
        prefix_hit_rate_delta = round(prefix_hits_delta / prefix_queries_delta, 4)
    else:
        prefix_hit_rate_delta = ""
    return {
        "prefix_queries_delta": prefix_queries_delta,
        "prefix_hits_delta": prefix_hits_delta,
        "prefix_misses_delta": prefix_misses_delta,
        "prefix_hit_rate_delta": prefix_hit_rate_delta,
        "kv_cache_usage_before": before.get("kv_cache_usage", ""),
        "kv_cache_usage_after": after.get("kv_cache_usage", ""),
        "running_requests_before": before.get("running_requests", ""),
        "running_requests_after": after.get("running_requests", ""),
        "waiting_requests_before": before.get("waiting_requests", ""),
        "waiting_requests_after": after.get("waiting_requests", ""),
    }


class BackpressureMonitor:
    def __init__(self, config: Config) -> None:
        self.config = config
        self.mode = "normal"
        self.backpressure_until = 0.0
        self.kv_high_streak = 0
        self.kv_exit_streak = 0
        self.waiting_high_streak = 0
        self.recent_server_error_count = 0
        self.last_poll = 0.0
        self.last_snapshot: Dict[str, float] = {}
        self.consecutive_metrics_failures = 0
        self.lock = threading.Lock()

    def record_server_error(self) -> None:
        with self.lock:
            self.recent_server_error_count += 1

    def record_success(self) -> None:
        with self.lock:
            self.recent_server_error_count = 0

    def poll_if_needed(self) -> None:
        now = time.time()
        with self.lock:
            if now - self.last_poll < self.config.metrics_poll_seconds:
                return
            self.last_poll = now

        snapshot = get_vllm_metrics_snapshot(self.config.metrics_url)

        if not snapshot:
            with self.lock:
                self.consecutive_metrics_failures += 1
                failures = self.consecutive_metrics_failures
            # Metrics-based backpressure is blind while this is happening (kv/waiting
            # default to 0, so kv/waiting-based triggers cannot fire). Surface this
            # periodically rather than only once at startup, so a metrics outage
            # mid-run doesn't silently disable the safety mechanism.
            if failures == 1 or failures % 10 == 0:
                print(
                    f"WARNING: vLLM metrics unreachable at {self.config.metrics_url} "
                    f"({failures} consecutive failed polls). KV/waiting-based backpressure "
                    f"is not active; only server-error-based abort logic is protecting the run."
                )
            return

        with self.lock:
            self.consecutive_metrics_failures = 0

        kv = float(snapshot.get("kv_cache_usage", 0.0) or 0.0)
        waiting = float(snapshot.get("waiting_requests", 0.0) or 0.0)

        with self.lock:
            self.last_snapshot = snapshot

            if kv >= self.config.kv_streak_backpressure:
                self.kv_high_streak += 1
            else:
                self.kv_high_streak = 0

            # Exit streak: counts consecutive polls where kv is already below the
            # exit threshold, independent of mode, so it's "warmed up" by the time
            # the minimum hold (backpressure_until) elapses instead of starting
            # from zero at that moment.
            if kv < self.config.kv_exit_backpressure:
                self.kv_exit_streak += 1
            else:
                self.kv_exit_streak = 0

            if waiting >= self.config.waiting_high:
                self.waiting_high_streak += 1
            else:
                self.waiting_high_streak = 0

            enter = (
                kv >= self.config.kv_immediate_backpressure
                or self.kv_high_streak >= self.config.kv_streak_checks
                or self.waiting_high_streak >= self.config.waiting_high_streak_checks
            )

            if enter and self.mode != "backpressure":
                self.mode = "backpressure"
                self.backpressure_until = now + self.config.backpressure_duration_seconds
                print(
                    f"[BACKPRESSURE ENTER] kv={kv:.4f} waiting={waiting} "
                    f"workers={self.config.backpressure_workers} duration_sec={self.config.backpressure_duration_seconds}"
                )

            if self.mode == "backpressure" and now >= self.backpressure_until:
                no_recent_errors = self.recent_server_error_count == 0
                exit_streak_ok = self.kv_exit_streak >= self.config.kv_exit_streak_checks
                if exit_streak_ok and waiting == 0 and no_recent_errors:
                    final_streak = self.kv_exit_streak
                    self.mode = "normal"
                    self.kv_high_streak = 0
                    self.kv_exit_streak = 0
                    self.waiting_high_streak = 0
                    print(f"[BACKPRESSURE EXIT] kv={kv:.4f} waiting={waiting} exit_streak={final_streak}")
                else:
                    self.backpressure_until = now + self.config.backpressure_duration_seconds
                    print(
                        f"[BACKPRESSURE EXTEND] kv={kv:.4f} waiting={waiting} "
                        f"exit_streak={self.kv_exit_streak}/{self.config.kv_exit_streak_checks} "
                        f"recent_errors={self.recent_server_error_count}"
                    )

    def current_limits(self) -> Tuple[str, int]:
        self.poll_if_needed()
        with self.lock:
            if self.mode == "backpressure":
                workers = self.config.backpressure_workers
            else:
                workers = self.config.normal_workers
        return self.mode, workers


