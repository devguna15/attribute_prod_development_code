class StopRequested(Exception):
    pass


class Runner:
    def __init__(self, config: Config) -> None:
        self.config = config
        self.writer = OutputWriter(
            config.output_dir,
            clear_existing=config.clear_existing_outputs,
            use_sqlite_status=config.use_sqlite_status,
            status_db_filename=config.status_db_filename,
            migrate_master_status_to_sqlite=config.migrate_master_status_to_sqlite,
        )
        self.status_store = self.writer.status_store
        self.completed_uuids = {} if self.status_store is not None else load_completed_uuids(self.writer.files["master_status"])
        self.completed_count = self.status_store.count_completed() if self.status_store is not None else len(self.completed_uuids)
        self.client = OpenAI(base_url=config.base_url, api_key=config.api_key)
        self.monitor = BackpressureMonitor(config)
        self.stop_event = threading.Event()
        self.batch_id = 0
        self.total_success = 0
        self.total_low = 0
        self.total_errors = 0
        self.total_server_failed = 0
        self.consecutive_server_failures = 0

    def request_stop(self, signum=None, frame=None) -> None:
        print("\nStop requested. Waiting for current completed futures to be written safely...")
        self.stop_event.set()

    def next_batch_id(self) -> int:
        self.batch_id += 1
        return self.batch_id

    def run(self) -> None:
        print("========== ATTRIBUTE PRODUCTION RUN START ==========")
        print(f"Model: {self.config.model_name}")
        print(f"Input file: {self.config.input_file}")
        print(f"Output dir: {self.config.output_dir}")
        print(f"Batch size: {self.config.batch_size}")
        print(f"Normal workers: {self.config.normal_workers}")
        print(f"Backpressure workers: {self.config.backpressure_workers}")
        print(f"Resume backend: {'SQLite status.db' if self.status_store is not None else 'CSV master_status.csv'}")
        if self.status_store is not None:
            print(f"Status DB: {self.writer.files['status_db']}")
        print(f"Completed rows from resume backend: {self.completed_count}")
        print("====================================================")

        check_server_startup(self.config)

        total_valid_rows, already_completed_rows, pending_rows = count_workload(self.config, self.completed_uuids, self.status_store)
        total_batches = (pending_rows + self.config.batch_size - 1) // self.config.batch_size if pending_rows else 0

        print("\n========== RUN WORKLOAD SUMMARY ==========")
        print(f"Total valid input rows: {total_valid_rows}")
        print(f"Already completed/skipped rows: {already_completed_rows}")
        print(f"Rows pending this run: {pending_rows}")
        print(f"Total batches this run: {total_batches}")
        print("==========================================\n")

        run_start_perf = time.perf_counter()
        completed_batches = 0
        processed_rows_this_run = 0

        rows_iter = input_row_generator(self.config, self.completed_uuids, self.status_store)
        batches_iter = batch_generator(rows_iter, self.config.batch_size)
        futures: Dict = {}
        exhausted = False

        executor = ThreadPoolExecutor(max_workers=self.config.normal_workers)
        try:
            try:
                while not exhausted or futures:
                    if self.stop_event.is_set():
                        raise StopRequested()

                    mode, allowed_workers = self.monitor.current_limits()

                    # len(futures) IS the current in-flight/concurrency count, so the
                    # submit gate must use allowed_workers (12 in backpressure, 40 in
                    # normal mode) -- not max_in_flight, which was only ever a queue
                    # multiplier and did not actually reduce concurrent requests.
                    while not exhausted and len(futures) < allowed_workers and not self.stop_event.is_set():
                        try:
                            batch_rows = next(batches_iter)
                        except StopIteration:
                            exhausted = True
                            break
                        batch_id = self.next_batch_id()
                        future = executor.submit(call_model_batch, self.client, self.config, batch_id, batch_rows, mode)
                        futures[future] = (batch_id, batch_rows)

                    if not futures:
                        break

                    done, _ = wait(set(futures.keys()), timeout=5, return_when=FIRST_COMPLETED)
                    if not done:
                        self.monitor.poll_if_needed()
                        continue

                    for future in done:
                        batch_id, batch_rows = futures.pop(future)
                        try:
                            result = future.result()
                        except Exception as exc:
                            error_type, error_text = classify_exception(exc)
                            if error_type == "server_failed_oom":
                                self.writer.write_oom_rows(batch_rows, batch_id, error_text, 1)
                                print(f"OOM detected for batch {batch_id}. Aborting immediately.")
                                raise StopRequested()
                            metric_row = make_metric_row(
                                batch_id=batch_id,
                                rows=batch_rows,
                                status="server_failed",
                                mode=mode,
                                attempts_used=1,
                                error_type=error_type,
                                error=error_text,
                                start_ts="",
                                end_ts=utc_now_iso(),
                                duration=None,
                                usage=None,
                                vllm_delta={},
                            )
                            result = build_server_failed_result(batch_id, batch_rows, error_type, error_text, 1, mode, metric_row)

                        self.writer.write_batch_result(result)
                        self.update_counts_and_failures(result)

                        completed_batches += 1
                        processed_rows_this_run += len(batch_rows)
                        elapsed = time.perf_counter() - run_start_perf
                        avg_rows_sec = processed_rows_this_run / elapsed if elapsed > 0 else 0.0

                        print(
                            f"Completed batch {batch_id} ({completed_batches}/{total_batches}) | "
                            f"elapsed={format_elapsed(elapsed)} | "
                            f"cum_rows={processed_rows_this_run}/{pending_rows} | "
                            f"avg_rows_sec={avg_rows_sec:.3f} | "
                            f"status={result.metric_row.get('status')} | "
                            f"success={len(result.success_rows)} | low={len(result.low_attribute_rows)} | "
                            f"errors={len(result.error_rows)} | server_failed={len(result.server_failed_rows)} | "
                            f"consecutive_server_failures={self.consecutive_server_failures}"
                        )

                        if result.outcome == BatchOutcome.SERVER_FAILED_OOM:
                            print(f"OOM detected for batch {batch_id}. Aborting immediately.")
                            raise StopRequested()

                        if self.consecutive_server_failures >= self.config.max_consecutive_server_failures:
                            print(
                                f"Aborting: consecutive server failed batches reached "
                                f"{self.consecutive_server_failures}."
                            )
                            raise StopRequested()

            except StopRequested:
                self.stop_event.set()
            finally:
                if futures:
                    print(
                        f"\nWaiting up to {self.config.graceful_shutdown_wait_seconds} sec "
                        f"for {len(futures)} in-flight batch(es) to finish before exiting safely..."
                    )
                    done_futures, not_done_futures = wait(
                        set(futures.keys()),
                        timeout=self.config.graceful_shutdown_wait_seconds,
                        return_when=ALL_COMPLETED,
                    )

                    for future in done_futures:
                        popped = futures.pop(future, None)
                        if popped is None:
                            continue
                        batch_id, batch_rows = popped
                        try:
                            result = future.result()
                        except Exception as exc:
                            error_type, error_text = classify_exception(exc)
                            metric_row = make_metric_row(
                                batch_id=batch_id,
                                rows=batch_rows,
                                status="server_failed",
                                mode="shutdown_drain",
                                attempts_used=1,
                                error_type=error_type,
                                error=error_text,
                                start_ts="",
                                end_ts=utc_now_iso(),
                                duration=None,
                                usage=None,
                                vllm_delta={},
                            )
                            result = build_server_failed_result(
                                batch_id=batch_id,
                                batch_rows=batch_rows,
                                error_type=error_type,
                                error=error_text,
                                attempts=1,
                                mode="shutdown_drain",
                                metric_row=metric_row,
                            )

                        self.writer.write_batch_result(result)
                        self.update_counts_and_failures(result)
                        completed_batches += 1
                        processed_rows_this_run += len(batch_rows)

                    if done_futures:
                        print(f"Saved {len(done_futures)} in-flight batch(es) during shutdown drain.")

                    if not_done_futures:
                        unsaved_rows = sum(len(futures[f][1]) for f in not_done_futures if f in futures)
                        print(
                            f"Shutdown drain timeout reached. {len(not_done_futures)} batch(es), "
                            f"{unsaved_rows} row(s) were not saved. They will be retried on next resume."
                        )
        finally:
            executor.shutdown(wait=False, cancel_futures=True)

        total_elapsed = time.perf_counter() - run_start_perf
        final_avg_rows_sec = processed_rows_this_run / total_elapsed if total_elapsed > 0 else 0.0

        print("\n========== ATTRIBUTE PRODUCTION RUN COMPLETE/STOPPED ==========")
        print(f"Total processing time: {format_elapsed(total_elapsed)} ({total_elapsed:.2f} sec)")
        print(f"Total processed rows this run: {processed_rows_this_run}")
        print(f"Average throughput: {final_avg_rows_sec:.3f} rows/sec")
        print(f"Successful output rows: {self.total_success}")
        print(f"Low attribute rows: {self.total_low}")
        print(f"Model/error rows: {self.total_errors}")
        print(f"Server failed rows: {self.total_server_failed}")
        if self.status_store is not None:
            print(f"SQLite status DB: {self.writer.files['status_db']}")
        print(f"Master status audit CSV: {self.writer.files['master_status']}")
        print("===============================================================")

    def update_counts_and_failures(self, result: BatchResult) -> None:
        self.total_success += len(result.success_rows)
        self.total_low += len(result.low_attribute_rows)
        self.total_errors += len(result.error_rows)
        self.total_server_failed += len(result.server_failed_rows)

        if result.outcome in (BatchOutcome.SERVER_FAILED, BatchOutcome.SERVER_FAILED_OOM):
            self.consecutive_server_failures += 1
            self.monitor.record_server_error()
        else:
            self.consecutive_server_failures = 0
            self.monitor.record_success()


