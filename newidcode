def parse_args() -> Config:
    """Build config from USER CONFIG section at top of file.

    No terminal arguments are required. Edit INPUT_FILE, OUTPUT_DIR, and column
    names at the top of this script. MAX_RECORDS can be "AUTO", None, or an int.
    """
    if isinstance(MAX_RECORDS, str) and MAX_RECORDS.strip().upper() == "AUTO":
        resolved_max_records = count_valid_csv_rows_for_max_records(
            INPUT_FILE,
            DEFAULT_CHUNKSIZE,
            HS_CODE_COLUMN,
            DESCRIPTION_COLUMN,
            UUID_COLUMN,
        )
        print(f"AUTO MAX_RECORDS resolved from CSV valid rows: {resolved_max_records}")
    else:
        resolved_max_records = MAX_RECORDS

    return Config(
        input_file=INPUT_FILE,
        output_dir=OUTPUT_DIR,
        base_url=DEFAULT_BASE_URL,
        metrics_url=DEFAULT_VLLM_METRICS_URL,
        api_key=DEFAULT_API_KEY,
        model_name=DEFAULT_MODEL_NAME,
        batch_size=DEFAULT_BATCH_SIZE,
        normal_workers=DEFAULT_NORMAL_WORKERS,
        backpressure_workers=DEFAULT_BACKPRESSURE_WORKERS,
        max_tokens=DEFAULT_MAX_TOKENS,
        graceful_shutdown_wait_seconds=DEFAULT_GRACEFUL_SHUTDOWN_WAIT_SECONDS,
        request_timeout_seconds=DEFAULT_REQUEST_TIMEOUT_SECONDS,
        server_max_attempts=DEFAULT_SERVER_MAX_ATTEMPTS,
        backoff_seconds=DEFAULT_BACKOFF_SECONDS,
        max_consecutive_server_failures=DEFAULT_MAX_CONSECUTIVE_SERVER_FAILURES,
        metrics_poll_seconds=DEFAULT_METRICS_POLL_SECONDS,
        backpressure_duration_seconds=DEFAULT_BACKPRESSURE_DURATION_SECONDS,
        kv_immediate_backpressure=DEFAULT_KV_IMMEDIATE_BACKPRESSURE,
        kv_streak_backpressure=DEFAULT_KV_STREAK_BACKPRESSURE,
        kv_streak_checks=DEFAULT_KV_STREAK_CHECKS,
        kv_exit_streak_checks=DEFAULT_KV_EXIT_STREAK_CHECKS,
        kv_exit_backpressure=DEFAULT_KV_EXIT_BACKPRESSURE,
        waiting_high=DEFAULT_WAITING_HIGH,
        waiting_high_streak_checks=DEFAULT_WAITING_HIGH_STREAK_CHECKS,
        chunksize=DEFAULT_CHUNKSIZE,
        max_records=resolved_max_records,
        clear_existing_outputs=CLEAR_EXISTING_OUTPUTS,
        hs_code_column=HS_CODE_COLUMN,
        description_column=DESCRIPTION_COLUMN,
        uuid_column=UUID_COLUMN,
        use_sqlite_status=USE_SQLITE_STATUS,
        status_db_filename=STATUS_DB_FILENAME,
        migrate_master_status_to_sqlite=MIGRATE_MASTER_STATUS_TO_SQLITE,
    )

def main() -> None:
    config = parse_args()
    runner = Runner(config)
    signal.signal(signal.SIGINT, runner.request_stop)
    signal.signal(signal.SIGTERM, runner.request_stop)
    try:
        runner.run()
    finally:
        runner.writer.close()


if __name__ == "__main__":
    main()
