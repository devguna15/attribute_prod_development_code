                "product_description": row.product_description,
            }
        )
    return PROMPT_TEMPLATE.format(items_json=json.dumps({"items": items}, ensure_ascii=False))


def clean_json_text(text: str) -> str:
    cleaned = str(text).strip()
    if cleaned.startswith("```"):
        cleaned = re.sub(r"^```(?:json)?\s*", "", cleaned, flags=re.IGNORECASE)
        cleaned = re.sub(r"\s*```$", "", cleaned)
    return cleaned.strip()


def extract_json_object(text: str) -> Dict:
    cleaned = clean_json_text(text)
    try:
        parsed = json.loads(cleaned)
        if isinstance(parsed, dict):
            return parsed
    except Exception:
        pass

    start = cleaned.find("{")
    end = cleaned.rfind("}")
    if start == -1 or end == -1 or end <= start:
        raise ValueError("No JSON object found in model output")
    parsed = json.loads(cleaned[start:end + 1])
    if not isinstance(parsed, dict):
        raise ValueError("Parsed output is not a JSON object")
    return parsed


def normalize_product_type(value) -> str:
    if isinstance(value, list):
        value = ", ".join(str(x) for x in value)
    return normalize_text(value)


def normalize_attributes(value) -> Dict:
    return value if isinstance(value, dict) else {}


def normalize_products_list(value) -> List[Dict]:
    return [x for x in value if isinstance(x, dict)] if isinstance(value, list) else []


def clean_empty_values(obj):
    """Remove null/empty-string/empty-list/empty-dict recursively from dict/list."""
    if isinstance(obj, dict):
        cleaned = {}
        for key, value in obj.items():
            if value is None:
                continue
            new_value = clean_empty_values(value)
            if new_value in ("", [], {}):
                continue
            cleaned[key] = new_value
        return cleaned
    if isinstance(obj, list):
        cleaned_list = [clean_empty_values(x) for x in obj]
        return [x for x in cleaned_list if x not in ("", [], {}, None)]
    if isinstance(obj, str):
        return normalize_text(obj)
    return obj


def attribute_count_for_result(product_type: str, attributes_obj: Dict) -> int:
    if not product_type:
        return 0
    if attributes_obj.get("nested") is True:
        products = attributes_obj.get("products", [])
        count = 0
        if isinstance(products, list):
            for product in products:
                if isinstance(product, dict):
                    count += sum(1 for key in product.keys() if key != "Product Type")
        return count
    return sum(1 for key in attributes_obj.keys() if key != "nested")


def classify_exception(exc: Exception, response_text: str = "") -> Tuple[str, str]:
    text = f"{type(exc).__name__}: {exc} {response_text}"
    lower = text.lower()
    if is_oom_text(lower):
        return "server_failed_oom", text
    if any(token in lower for token in ["timeout", "timed out", "readtimeout", "connecttimeout"]):
        return "server_timeout", text
    if any(token in lower for token in ["connection reset", "connection refused", "remote disconnected", "connection aborted", "connectionerror"]):
        return "server_connection", text
    if any(token in lower for token in ["status code: 500", "status_code=500", " 500 ", "internal server error"]):
        return "server_http_500", text
    if any(token in lower for token in ["status code: 502", "status_code=502", " 502 ", "bad gateway"]):
        return "server_http_502", text
    if any(token in lower for token in ["status code: 503", "status_code=503", " 503 ", "service unavailable"]):
        return "server_http_503", text
    if any(token in lower for token in ["status code: 504", "status_code=504", " 504 ", "gateway timeout"]):
        return "server_http_504", text
    return "server_unknown", text


def make_metric_row(
    batch_id: int,
    rows: List[InputRow],
    status: str,
    mode: str,
    attempts_used: int,
    error_type: str,
    error: str,
    start_ts: str,
    end_ts: str,
    duration: Optional[float],
    usage,
    vllm_delta: Dict,
) -> Dict:
    return {
        "batch_id": batch_id,
        "rows_in_batch": len(rows),
        "row_ids": ";".join(str(row.row_id) for row in rows),
        "status": status,
        "mode": mode,
        "attempts_used": attempts_used,
        "error_type": error_type,
        "error": error,
        "start_ts_utc": start_ts,
        "end_ts_utc": end_ts,
        "request_duration_sec": round(duration, 4) if duration is not None else "",
        "rows_per_sec": round(len(rows) / duration, 4) if duration and duration > 0 else "",
        "prompt_tokens_api": getattr(usage, "prompt_tokens", "") if usage else "",
        "completion_tokens_api": getattr(usage, "completion_tokens", "") if usage else "",
        "total_tokens_api": getattr(usage, "total_tokens", "") if usage else "",
        "prefix_queries_delta": vllm_delta.get("prefix_queries_delta", ""),
        "prefix_hits_delta": vllm_delta.get("prefix_hits_delta", ""),
        "prefix_misses_delta": vllm_delta.get("prefix_misses_delta", ""),
        "prefix_hit_rate_delta": vllm_delta.get("prefix_hit_rate_delta", ""),
        "kv_cache_usage_before": vllm_delta.get("kv_cache_usage_before", ""),
        "kv_cache_usage_after": vllm_delta.get("kv_cache_usage_after", ""),
        "running_requests_before": vllm_delta.get("running_requests_before", ""),
        "running_requests_after": vllm_delta.get("running_requests_after", ""),
        "waiting_requests_before": vllm_delta.get("waiting_requests_before", ""),
        "waiting_requests_after": vllm_delta.get("waiting_requests_after", ""),
    }


def call_model_batch(
    client: OpenAI,
    config: Config,
    batch_id: int,
    batch_rows: List[InputRow],
    mode: str,
) -> BatchResult:
    prompt = build_batch_prompt(batch_rows)
    last_error = ""
    last_error_type = ""
    last_content = ""
    start_ts = ""
    end_ts = ""
    duration = None
    usage = None
    vllm_delta: Dict = {}

    for attempt in range(1, config.server_max_attempts + 1):
        if attempt > 1:
            sleep_seconds = config.backoff_seconds[min(attempt - 2, len(config.backoff_seconds) - 1)]
            time.sleep(sleep_seconds)

        request_start_perf = time.perf_counter()
        start_ts = utc_now_iso()
        before = get_vllm_metrics_snapshot(config.metrics_url)

        try:
            response = client.chat.completions.create(
                model=config.model_name,
                temperature=0,
                max_tokens=config.max_tokens,
                response_format={"type": "json_object"},
                timeout=config.request_timeout_seconds,
                messages=[
                    {"role": "system", "content": SYSTEM_PROMPT},
                    {"role": "user", "content": prompt},
                ],
            )
            end_ts = utc_now_iso()
            after = get_vllm_metrics_snapshot(config.metrics_url)
            duration = time.perf_counter() - request_start_perf
            vllm_delta = build_vllm_metrics_delta(before, after)
            usage = getattr(response, "usage", None)

            content = response.choices[0].message.content or "{}"
            last_content = content
            parsed = extract_json_object(content)
            results = parsed.get("results")
            if not isinstance(results, list):
                raise ValueError("Model output does not contain results array")

            return build_success_or_model_error_result(
                batch_id=batch_id,
                batch_rows=batch_rows,
                results=results,
                raw_model_output=last_content,
                attempts=attempt,
                metric_row=make_metric_row(
                    batch_id=batch_id,
                    rows=batch_rows,
                    status="success",
                    mode=mode,
                    attempts_used=attempt,
                    error_type="",
                    error="",
                    start_ts=start_ts,
                    end_ts=end_ts,
                    duration=duration,
                    usage=usage,
                    vllm_delta=vllm_delta,
                ),
            )

        except ValueError as exc:
            # Model output / JSON / validation issue. Do not server-retry forever.
            error_type = "truncated" if looks_truncated(last_content) else "model_error"
            error_text = str(exc)
            end_ts = utc_now_iso()
            after = get_vllm_metrics_snapshot(config.metrics_url)
            duration = time.perf_counter() - request_start_perf
            vllm_delta = build_vllm_metrics_delta(before, after)
            return build_full_model_error_result(
                batch_id=batch_id,
                batch_rows=batch_rows,
                error_type=error_type,
                error=error_text,
                raw_model_output=last_content,
                attempts=attempt,
                mode=mode,
                metric_row=make_metric_row(
                    batch_id=batch_id,
                    rows=batch_rows,
                    status=error_type,
                    mode=mode,
                    attempts_used=attempt,
                    error_type=error_type,
                    error=error_text,
                    start_ts=start_ts,
                    end_ts=end_ts,
                    duration=duration,
                    usage=usage,
                    vllm_delta=vllm_delta,
                ),
            )

        except Exception as exc:
            last_error_type, last_error = classify_exception(exc)
            if last_error_type == "server_failed_oom":
                metric_row = make_metric_row(
                    batch_id=batch_id,
                    rows=batch_rows,
                    status="server_failed_oom",
                    mode=mode,
                    attempts_used=attempt,
                    error_type=last_error_type,
                    error=last_error,
                    start_ts=start_ts,
                    end_ts=utc_now_iso(),
                    duration=time.perf_counter() - request_start_perf,
                    usage=usage,
                    vllm_delta=build_vllm_metrics_delta(before, get_vllm_metrics_snapshot(config.metrics_url)),
                )
                return build_server_failed_result(
                    batch_id=batch_id,
                    batch_rows=batch_rows,
                    error_type="server_failed_oom",
                    error=last_error,
                    attempts=attempt,
                    mode=mode,
                    metric_row=metric_row,
                )

            if attempt >= config.server_max_attempts:
                break

    metric_row = make_metric_row(
        batch_id=batch_id,
        rows=batch_rows,
        status="server_failed",
        mode=mode,
        attempts_used=config.server_max_attempts,
        error_type=last_error_type,
        error=last_error,
        start_ts=start_ts,
        end_ts=utc_now_iso(),
        duration=duration,
        usage=usage,
        vllm_delta=vllm_delta,
    )
    return build_server_failed_result(
        batch_id=batch_id,
        batch_rows=batch_rows,
        error_type=last_error_type or "server_failed",
        error=last_error,
        attempts=config.server_max_attempts,
        mode=mode,
        metric_row=metric_row,
    )


def build_success_or_model_error_result(
    batch_id: int,
    batch_rows: List[InputRow],
    results: List[Dict],
    raw_model_output: str,
    metric_row: Dict,
    attempts: int = 1,
) -> BatchResult:
    results_by_row_id: Dict[int, Dict] = {}
    duplicate_ids = set()
    for item in results:
        if not isinstance(item, dict):
            continue
        try:
            row_id = int(item.get("row_id"))
        except Exception:
            continue
        if row_id in results_by_row_id:
            duplicate_ids.add(row_id)
        results_by_row_id[row_id] = item

    success_rows: List[Dict] = []
    low_rows: List[Dict] = []
    error_rows: List[Dict] = []
    status_rows: List[Dict] = []
    row_id_mismatch_count = 0
    now = utc_now_iso()

    for row in batch_rows:
        result_item = results_by_row_id.get(row.row_id)
        if result_item is None:
            error_type = "missing_result"
            status = FinalStatus.MODEL_ERROR.value
            error_rows.append(error_row(row, batch_id, error_type, "Missing result for row_id", raw_model_output))
            status_rows.append(status_row(row, batch_id, status, "error_output.csv", error_type, attempts, now))
            row_id_mismatch_count += 1
            continue

        if row.row_id in duplicate_ids:
            error_type = "duplicate_result"
            status = FinalStatus.MODEL_ERROR.value
            error_rows.append(error_row(row, batch_id, error_type, "Duplicate result for row_id", raw_model_output))
            status_rows.append(status_row(row, batch_id, status, "error_output.csv", error_type, attempts, now))
            row_id_mismatch_count += 1
            continue

        try:
            nested = result_item.get("nested", False)
            if nested is True:
                products = normalize_products_list(result_item.get("products", []))
                score = result_item.get("canonical_similarity_score", "")
                try:
                    score = float(score)
                except Exception:
                    score = ""
                product_type = "NESTED"
                attributes_obj = clean_empty_values(
                    {
                        "nested": True,
                        "canonical_similarity_score": score,
                        "products": products,
                    }
                )
                if not products:
                    raise ValueError("Nested result has empty products list")
            else:
                product_type = normalize_product_type(result_item.get("Product Type", ""))
                attributes = clean_empty_values(normalize_attributes(result_item.get("Attributes", {})))
                attributes_obj = {"nested": False, **attributes}
                if not product_type:
                    raise ValueError("Product Type is empty")

            out = {
                "row_id": row.row_id,
                "record_uuid": row.record_uuid,
                "hs_code": row.hs_code,
                "product_description": row.product_description,
                "product_type": product_type,
                "attributes": json.dumps(attributes_obj, ensure_ascii=False),
            }
            attr_len = attribute_count_for_result(product_type, attributes_obj)
            if attr_len <= LOW_ATTRIBUTE_THRESHOLD:
                low_rows.append(out)
                status_rows.append(status_row(row, batch_id, FinalStatus.LOW_ATTRIBUTE.value, "low_attribute_output.csv", "", attempts, now))
            else:
                success_rows.append(out)
                status_rows.append(status_row(row, batch_id, FinalStatus.SUCCESS.value, "success_output.csv", "", attempts, now))

        except Exception as exc:
            error_type = "validation_error"
            error_rows.append(error_row(row, batch_id, error_type, str(exc), raw_model_output))
            status_rows.append(status_row(row, batch_id, FinalStatus.MODEL_ERROR.value, "error_output.csv", error_type, attempts, now))

    if error_rows:
        metric_row["status"] = "partial_model_error" if (success_rows or low_rows) else "model_error"
        metric_row["error_type"] = "row_level_model_error"
        metric_row["error"] = f"{len(error_rows)} row(s) missing/duplicate/invalid"

    # If row_id mismatches (missing or duplicate) account for over half the batch,
    # this is very unlikely to be a per-row issue -- it usually means the model
    # returned malformed/misaligned row_ids for the whole batch. These rows still
    # get MODEL_ERROR status and, importantly, master_status.csv treats any status
    # as "completed" -- so they will NOT be retried on resume. Surface this loudly
    # here since it would otherwise disappear silently into individual error rows.
    if batch_rows and row_id_mismatch_count > len(batch_rows) / 2:
        preview = raw_model_output[:300].replace("\n", " ")
        print(
            f"[ROW_ID MISMATCH] batch_id={batch_id} {row_id_mismatch_count}/{len(batch_rows)} rows "
            f"missing/duplicate row_id in model response -- likely a malformed/misaligned response, "
            f"not isolated per-row errors. These rows will be marked model_error and SKIPPED on future "
            f"resume runs (master_status treats any status as complete). raw_output_preview={preview!r}"
        )

    return BatchResult(
        batch_id=batch_id,
        rows=batch_rows,
        outcome=BatchOutcome.PARTIAL_MODEL_ERROR if error_rows else BatchOutcome.SUCCESS,
        success_rows=success_rows,
        low_attribute_rows=low_rows,
        error_rows=error_rows,
        server_failed_rows=[],
        status_rows=status_rows,
        metric_row=metric_row,
        raw_model_output=raw_model_output,
    )


def build_full_model_error_result(
    batch_id: int,
    batch_rows: List[InputRow],
    error_type: str,
    error: str,
    raw_model_output: str,
    attempts: int,
    mode: str,
    metric_row: Dict,
) -> BatchResult:
    now = utc_now_iso()
    status = FinalStatus.TRUNCATED.value if error_type == "truncated" else FinalStatus.MODEL_ERROR.value
    error_rows = [error_row(row, batch_id, error_type, error, raw_model_output) for row in batch_rows]
    status_rows = [status_row(row, batch_id, status, "error_output.csv", error_type, attempts, now) for row in batch_rows]
    return BatchResult(
        batch_id=batch_id,
        rows=batch_rows,
        outcome=BatchOutcome.PARTIAL_MODEL_ERROR,
        success_rows=[],
        low_attribute_rows=[],
        error_rows=error_rows,
        server_failed_rows=[],
        status_rows=status_rows,
        metric_row=metric_row,
        raw_model_output=raw_model_output,
    )


def build_server_failed_result(
    batch_id: int,
    batch_rows: List[InputRow],
    error_type: str,
    error: str,
    attempts: int,
    mode: str,
    metric_row: Dict,
) -> BatchResult:
    now = utc_now_iso()
    is_oom = error_type == "server_failed_oom"
    status = FinalStatus.SERVER_FAILED_OOM.value if is_oom else FinalStatus.SERVER_FAILED.value
    output_file = "server_failed_oom_output.csv" if is_oom else "server_failed_output.csv"
    server_rows = [server_failed_row(row, batch_id, error_type, error) for row in batch_rows]
    status_rows = [status_row(row, batch_id, status, output_file, error_type, attempts, now) for row in batch_rows]
    return BatchResult(
        batch_id=batch_id,
        rows=batch_rows,
        outcome=BatchOutcome.SERVER_FAILED_OOM if error_type == "server_failed_oom" else BatchOutcome.SERVER_FAILED,
        success_rows=[],
        low_attribute_rows=[],
        error_rows=[],
        server_failed_rows=server_rows,
        status_rows=status_rows,
        metric_row=metric_row,
        server_error_type=error_type,
    )


def error_row(row: InputRow, batch_id: int, error_type: str, error: str, raw_model_output: str) -> Dict:
    return {
        "row_id": row.row_id,
        "record_uuid": row.record_uuid,
        "batch_id": batch_id,
        "hs_code": row.hs_code,
