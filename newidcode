def detect_columns(
    df: pd.DataFrame,
    hs_code_column: str,
    description_column: str,
    uuid_column: str,
) -> Tuple[str, str, str]:
    cols = list(df.columns)
    normalized = {c.lower().strip(): c for c in cols}

    def resolve_configured(configured: str, label: str) -> Optional[str]:
        if not configured:
            return None
        if configured in cols:
            return configured
        key = configured.lower().strip()
        if key in normalized:
            return normalized[key]
        raise ValueError(f"Configured {label} column not found: {configured}. Available columns: {cols}")

    hs_col = resolve_configured(hs_code_column, "HS code")
    desc_col = resolve_configured(description_column, "description")
    uuid_col = resolve_configured(uuid_column, "UUID")

    hs_candidates = ["hs_code", "hscode", "hs code", "hs", "itc_hs_code", "hsn", "hsn_code", "hsn code"]
    desc_candidates = [
        "product_description",
        "product description",
        "description",
        "item_description",
        "item description",
        "product_desc",
        "goods_description",
        "goods description",
        "product desc",
    ]
    uuid_candidates = ["uuid", "record_uuid", "record uuid", "row_uuid", "row uuid", "id", "record_id", "record id"]

    if hs_col is None:
        hs_col = next((normalized[c] for c in hs_candidates if c in normalized), None)
    if desc_col is None:
        desc_col = next((normalized[c] for c in desc_candidates if c in normalized), None)
    if uuid_col is None:
        uuid_col = next((normalized[c] for c in uuid_candidates if c in normalized), None)

    missing = []
    if hs_col is None:
        missing.append("hs_code")
    if desc_col is None:
        missing.append("product_description")
    if uuid_col is None:
        missing.append("UUID")
    if missing:
        raise ValueError(
            f"Could not auto-detect required column(s): {missing}. "
            f"Available columns: {cols}. Configure HS_CODE_COLUMN, DESCRIPTION_COLUMN, and UUID_COLUMN if needed."
        )

    return hs_col, desc_col, uuid_col


def iter_input_chunks(input_file: str, chunksize: int) -> Iterator[pd.DataFrame]:
    lower = input_file.lower()
    if lower.endswith(".csv"):
        yield from pd.read_csv(input_file, chunksize=chunksize)
        return
    if lower.endswith((".xlsx", ".xls")):
        raise NotImplementedError(
            "Excel input is disabled for production runs because pandas read_excel() "
            "loads the entire file into RAM and does not provide true chunksize streaming. "
            "Convert the input to .csv and set INPUT_FILE to the .csv path."
        )
    raise ValueError(f"Unsupported input file format: {input_file}. Use .csv for production runs.")


def count_valid_csv_rows_for_max_records(
    input_file: str,
    chunksize: int,
    hs_code_column: str,
    description_column: str,
    uuid_column: str,
) -> int:
    """Count valid processable CSV rows for AUTO MAX_RECORDS.

    A valid row has a non-empty product description and a non-empty UUID.
    This count is used only to avoid manually editing MAX_RECORDS for each file.
    """
    if not os.path.exists(input_file):
        raise FileNotFoundError(f"Input file not found: {input_file}")

    total = 0
    row_id = 0
    hs_col: Optional[str] = None
    desc_col: Optional[str] = None
    uuid_col: Optional[str] = None

    for chunk in iter_input_chunks(input_file, chunksize):
        if hs_col is None or desc_col is None or uuid_col is None:
            hs_col, desc_col, uuid_col = detect_columns(
                chunk,
                hs_code_column,
                description_column,
                uuid_column,
            )

        for _, raw_row in chunk.iterrows():
            row_id += 1
            product_description = normalize_text(raw_row.get(desc_col, ""))
            record_uuid = normalize_text(raw_row.get(uuid_col, ""))
            if not product_description:
                continue
            if not record_uuid:
                raise ValueError(f"Missing UUID at input row_id={row_id}. UUID is required for safe resume.")
            total += 1

    return total

def input_row_generator(
    config: Config,
    completed_uuids: Optional[Dict[str, str]] = None,
    status_store: Optional[StatusStore] = None,
) -> Iterator[InputRow]:
    if not os.path.exists(config.input_file):
        raise FileNotFoundError(f"Input file not found: {config.input_file}")

    completed_uuids = completed_uuids or {}
    row_id = 0
    yielded = 0
    hs_col: Optional[str] = None
    desc_col: Optional[str] = None
    uuid_col: Optional[str] = None

    for chunk in iter_input_chunks(config.input_file, config.chunksize):
        if hs_col is None or desc_col is None or uuid_col is None:
            hs_col, desc_col, uuid_col = detect_columns(
                chunk,
                config.hs_code_column,
                config.description_column,
                config.uuid_column,
            )
            print(f"Detected HS code column: {hs_col}")
            print(f"Detected description column: {desc_col}")
            print(f"Detected UUID column: {uuid_col}")

        prepared_rows: List[InputRow] = []
        for _, raw_row in chunk.iterrows():
            row_id += 1
            hs_code = normalize_text(raw_row.get(hs_col, ""))
            product_description = normalize_text(raw_row.get(desc_col, ""))
            record_uuid = normalize_text(raw_row.get(uuid_col, ""))
            if not product_description:
                continue
            if not record_uuid:
                raise ValueError(f"Missing UUID at input row_id={row_id}. UUID is required for safe resume.")

            prepared_rows.append(
                InputRow(
                    row_id=row_id,
                    record_uuid=record_uuid,
                    hs_code=hs_code,
                    product_description=product_description,
                )
            )

        if status_store is not None:
            completed_in_chunk = status_store.get_completed_uuids([row.record_uuid for row in prepared_rows])
        else:
            completed_in_chunk = set(completed_uuids.keys())

        for row in prepared_rows:
            if row.record_uuid in completed_in_chunk:
                continue
            yield row
            yielded += 1
            if config.max_records is not None and yielded >= config.max_records:
                return

def batch_generator(rows: Iterator[InputRow], batch_size: int) -> Iterator[List[InputRow]]:
    batch: List[InputRow] = []
    for row in rows:
        batch.append(row)
        if len(batch) >= batch_size:
            yield batch
            batch = []
    if batch:
        yield batch


def format_elapsed(seconds: float) -> str:
    seconds_int = int(max(seconds, 0))
    hours = seconds_int // 3600
    minutes = (seconds_int % 3600) // 60
    secs = seconds_int % 60
    if hours > 0:
        return f"{hours:02d}:{minutes:02d}:{secs:02d}"
    return f"{minutes:02d}:{secs:02d}"


def count_workload(
    config: Config,
    completed_uuids: Optional[Dict[str, str]] = None,
    status_store: Optional[StatusStore] = None,
) -> Tuple[int, int, int]:
    """Count valid rows, already completed rows, and pending rows for the run.

    With SQLite enabled, this scans input chunk-by-chunk and asks status.db only
    about UUIDs in the current chunk, avoiding a giant completed-UUID dict.
    """
    if not os.path.exists(config.input_file):
        raise FileNotFoundError(f"Input file not found: {config.input_file}")

    completed_uuids = completed_uuids or {}
    total_valid_rows = 0
    already_completed_rows = 0
    pending_rows = 0
    row_id = 0
    hs_col: Optional[str] = None
    desc_col: Optional[str] = None
    uuid_col: Optional[str] = None

    for chunk in iter_input_chunks(config.input_file, config.chunksize):
        if hs_col is None or desc_col is None or uuid_col is None:
            hs_col, desc_col, uuid_col = detect_columns(
                chunk,
                config.hs_code_column,
                config.description_column,
                config.uuid_column,
            )

        prepared: List[Tuple[str, str, str]] = []
        for _, raw_row in chunk.iterrows():
            row_id += 1
            hs_code = normalize_text(raw_row.get(hs_col, ""))
            product_description = normalize_text(raw_row.get(desc_col, ""))
            record_uuid = normalize_text(raw_row.get(uuid_col, ""))
            if not product_description:
                continue
            if not record_uuid:
                raise ValueError(f"Missing UUID at input row_id={row_id}. UUID is required for safe resume.")
            prepared.append((record_uuid, hs_code, product_description))

        if status_store is not None:
            completed_in_chunk = status_store.get_completed_uuids([x[0] for x in prepared])
        else:
            completed_in_chunk = set(completed_uuids.keys())

        for record_uuid, _, _ in prepared:
            total_valid_rows += 1
            if record_uuid in completed_in_chunk:
                already_completed_rows += 1
                continue
            pending_rows += 1
            if config.max_records is not None and pending_rows >= config.max_records:
                return total_valid_rows, already_completed_rows, pending_rows

    return total_valid_rows, already_completed_rows, pending_rows


