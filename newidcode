def check_server_startup(config: Config) -> None:
    models_url = config.base_url.rstrip("/") + "/models"
    try:
        response = requests.get(models_url, timeout=20)
        if response.status_code >= 400:
            raise RuntimeError(f"Server responded with HTTP {response.status_code}: {response.text[:300]}")
    except Exception as exc:
        raise RuntimeError(f"vLLM server is not reachable at {models_url}. Error: {exc}") from exc

    metrics = get_vllm_metrics_snapshot(config.metrics_url)
    if not metrics:
        print(f"WARNING: vLLM metrics not reachable or empty at {config.metrics_url}. Job can continue, but backpressure will be weaker.")


