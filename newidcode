class StatusStore:
    """SQLite-backed completed-status ledger used for scalable resume.

    The input CSV remains the source of all rows. This DB stores only rows that
    have reached a final status after a batch-level commit.
    """

    def __init__(self, db_path: str, master_status_path: str, migrate_from_master_status: bool = True) -> None:
        self.db_path = db_path
        self.master_status_path = master_status_path
        self.lock = threading.Lock()
        ensure_dir(os.path.dirname(db_path))
        db_existed = os.path.exists(db_path) and os.path.getsize(db_path) > 0
        self.conn = sqlite3.connect(db_path, timeout=30, check_same_thread=False)
        self._configure_connection()
        self._create_schema()
        if migrate_from_master_status and (not db_existed) and os.path.exists(master_status_path):
            self.migrate_master_status_csv(master_status_path)

    def _configure_connection(self) -> None:
        with self.lock:
            self.conn.execute("PRAGMA journal_mode=WAL;")
            self.conn.execute("PRAGMA synchronous=NORMAL;")
            self.conn.execute("PRAGMA temp_store=MEMORY;")
            self.conn.execute("PRAGMA cache_size=-200000;")
            self.conn.execute("PRAGMA busy_timeout=30000;")

    def _create_schema(self) -> None:
        with self.lock:
            self.conn.execute(
                """
                CREATE TABLE IF NOT EXISTS status (
                    record_uuid TEXT PRIMARY KEY,
                    row_id INTEGER,
                    batch_id INTEGER,
                    hs_code TEXT,
                    product_description TEXT,
                    status TEXT,
                    output_file TEXT,
                    error_type TEXT,
                    attempt_count INTEGER,
                    updated_at_utc TEXT
                )
                """
            )
            columns = {row[1]: row for row in self.conn.execute("PRAGMA table_info(status)").fetchall()}
            if "record_uuid" not in columns:
                raise RuntimeError(
                    "Existing status DB uses the old hash-based schema and does not contain record_uuid. "
                    "Use a fresh OUTPUT_DIR or a fresh STATUS_DB_FILENAME for the UUID-based runner."
                )
            if int(columns["record_uuid"][5]) != 1:
                raise RuntimeError(
                    "Existing status DB does not use record_uuid as the primary key. "
                    "Use a fresh OUTPUT_DIR or a fresh STATUS_DB_FILENAME for the UUID-based runner."
                )
            self.conn.execute("CREATE INDEX IF NOT EXISTS idx_status_row_id ON status(row_id)")
            self.conn.execute("CREATE INDEX IF NOT EXISTS idx_status_status ON status(status)")
            self.conn.commit()

    def close(self) -> None:
        with self.lock:
            self.conn.commit()
            self.conn.close()

    def count_completed(self) -> int:
        """Count rows with final/skippable statuses only.

        server_failed/server_failed_oom rows are intentionally not counted as
        completed for resume because they should be retried on the next run.
        """
        final_statuses = (
            FinalStatus.SUCCESS.value,
            FinalStatus.LOW_ATTRIBUTE.value,
            FinalStatus.MODEL_ERROR.value,
            FinalStatus.TRUNCATED.value,
        )
        placeholders = ",".join("?" for _ in final_statuses)
        with self.lock:
            row = self.conn.execute(
                f"SELECT COUNT(*) FROM status WHERE status IN ({placeholders})",
                final_statuses,
            ).fetchone()
        return int(row[0] if row else 0)

    def get_completed_uuids(self, record_uuids: List[str]) -> Set[str]:
        """Return UUIDs from record_uuids that already have final/skippable status.

        Server failure statuses are intentionally not returned, so those rows
        are retried instead of being skipped forever. Queries are split to stay
        below SQLite parameter limits.
        """
        cleaned = [u for u in record_uuids if u]
        if not cleaned:
            return set()

        final_statuses = (
            FinalStatus.SUCCESS.value,
            FinalStatus.LOW_ATTRIBUTE.value,
            FinalStatus.MODEL_ERROR.value,
            FinalStatus.TRUNCATED.value,
        )
        found: Set[str] = set()
        with self.lock:
            for start in range(0, len(cleaned), 800):
                part = cleaned[start:start + 800]
                uuid_placeholders = ",".join("?" for _ in part)
                status_placeholders = ",".join("?" for _ in final_statuses)
                query = f"""
                    SELECT record_uuid
                    FROM status
                    WHERE record_uuid IN ({uuid_placeholders})
                      AND status IN ({status_placeholders})
                """
                params = list(part) + list(final_statuses)
                found.update(row[0] for row in self.conn.execute(query, params).fetchall())
        return found

    def upsert_status_rows(self, rows: List[Dict]) -> None:
        if not rows:
            return
        payload = [
            (
                normalize_text(row.get("record_uuid", "")),
                int(row.get("row_id", 0) or 0),
                int(row.get("batch_id", 0) or 0),
                normalize_text(row.get("hs_code", "")),
                normalize_text(row.get("product_description", "")),
                normalize_text(row.get("status", "")),
                normalize_text(row.get("output_file", "")),
                normalize_text(row.get("error_type", "")),
                int(row.get("attempt_count", 0) or 0),
                normalize_text(row.get("updated_at_utc", "")),
            )
            for row in rows
            if normalize_text(row.get("record_uuid", ""))
        ]
        if not payload:
            return
        with self.lock:
            self.conn.executemany(
                """
                INSERT INTO status (
                    record_uuid, row_id, batch_id, hs_code, product_description,
                    status, output_file, error_type, attempt_count, updated_at_utc
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                ON CONFLICT(record_uuid) DO UPDATE SET
                    row_id=excluded.row_id,
                    batch_id=excluded.batch_id,
                    hs_code=excluded.hs_code,
                    product_description=excluded.product_description,
                    status=excluded.status,
                    output_file=excluded.output_file,
                    error_type=excluded.error_type,
                    attempt_count=excluded.attempt_count,
                    updated_at_utc=excluded.updated_at_utc
                """,
                payload,
            )
            self.conn.commit()

    def migrate_master_status_csv(self, master_status_path: str) -> None:
        """One-time migration from existing master_status.csv into status.db."""
        if not os.path.exists(master_status_path):
            return
        print(f"Migrating existing master_status.csv into SQLite status DB: {self.db_path}")
        batch: List[Dict] = []
        migrated = 0
        with open(master_status_path, "r", newline="", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                if normalize_text(row.get("record_uuid", "")):
                    batch.append(row)
                if len(batch) >= 5000:
                    self.upsert_status_rows(batch)
                    migrated += len(batch)
                    batch = []
            if batch:
                self.upsert_status_rows(batch)
                migrated += len(batch)
        print(f"SQLite migration complete. Migrated/updated status rows: {migrated}")


def load_completed_uuids(master_status_path: str) -> Dict[str, str]:
    """CSV fallback: Return record_uuid -> final_status from master_status.csv.

    The SQLite backend avoids this full-file load. This function remains only as
    rollback fallback when USE_SQLITE_STATUS = False.
    """
    completed: Dict[str, str] = {}
    if not os.path.exists(master_status_path):
        return completed
    with open(master_status_path, "r", newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            record_uuid = normalize_text(row.get("record_uuid", ""))
            status = normalize_text(row.get("status", ""))
            if record_uuid and status:
                completed[record_uuid] = status
    return completed


