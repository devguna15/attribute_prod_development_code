def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def normalize_text(value) -> str:
    if pd.isna(value):
        return ""
    return re.sub(r"\s+", " ", str(value).strip())


def get_domain(hs_code: str) -> str:
    try:
        hs_int = int(str(hs_code).strip().zfill(4)[:2])
        for key, value in HS_MAPPING.items():
            if "-" in key:
                lo, hi = map(int, key.split("-"))
                if lo <= hs_int <= hi:
                    return value
            elif int(key) == hs_int:
                return value
    except Exception:
        pass
    return "General Trade Goods"


def ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def is_oom_text(text: str) -> bool:
    lower = str(text).lower()
    return any(
        token in lower
        for token in [
            "cuda out of memory",
            "torch.outofmemoryerror",
            "outofmemoryerror",
            "out of memory",
            "oom",
        ]
    )


def looks_truncated(text: str) -> bool:
    cleaned = str(text).strip()
    if not cleaned:
        return False
    if is_oom_text(cleaned):
        return False
    # Common case: JSON starts but never closes.
    return cleaned.count("{") > cleaned.count("}") or cleaned.count("[") > cleaned.count("]")


