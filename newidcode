class OutputWriter:
    def __init__(
        self,
        output_dir: str,
        clear_existing: bool = False,
        use_sqlite_status: bool = True,
        status_db_filename: str = "status.db",
        migrate_master_status_to_sqlite: bool = True,
    ) -> None:
        ensure_dir(output_dir)
        self.output_dir = output_dir
        self.files = {
            "success": os.path.join(output_dir, "success_output.csv"),
            "low_attribute": os.path.join(output_dir, "low_attribute_output.csv"),
            "error": os.path.join(output_dir, "error_output.csv"),
            "server_failed": os.path.join(output_dir, "server_failed_output.csv"),
            "server_failed_oom": os.path.join(output_dir, "server_failed_oom_output.csv"),
            "master_status": os.path.join(output_dir, "master_status.csv"),
            "metrics": os.path.join(output_dir, "metrics.csv"),
            "status_db": os.path.join(output_dir, status_db_filename),
        }
        self.lock = threading.Lock()
        if clear_existing:
            for key, path in self.files.items():
                if key == "status_db":
                    for db_path in [path, path + "-wal", path + "-shm"]:
                        if os.path.exists(db_path):
                            os.remove(db_path)
                elif os.path.exists(path):
                    os.remove(path)

        self.status_store: Optional[StatusStore] = None
        if use_sqlite_status:
            self.status_store = StatusStore(
                db_path=self.files["status_db"],
                master_status_path=self.files["master_status"],
                migrate_from_master_status=migrate_master_status_to_sqlite,
            )

    def close(self) -> None:
        if self.status_store is not None:
            self.status_store.close()

    def _append_rows_locked(self, file_key: str, rows: List[Dict], fieldnames: List[str]) -> None:
        """Same as append_rows but assumes self.lock is already held by the caller."""
        if not rows:
            return
        path = self.files[file_key]
        file_exists = os.path.exists(path) and os.path.getsize(path) > 0
        with open(path, "a", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
            if not file_exists:
                writer.writeheader()
            for row in rows:
                writer.writerow(row)
            f.flush()
            os.fsync(f.fileno())

    def append_rows(self, file_key: str, rows: List[Dict], fieldnames: List[str]) -> None:
        with self.lock:
            self._append_rows_locked(file_key, rows, fieldnames)

    def write_batch_result(self, result: BatchResult) -> None:
        # Batch-level commit is preserved. Output CSVs are written first. Then
        # status.db is updated, then master_status.csv is appended for audit, and
        # metrics.csv is written. If a crash happens before status.db update,
        # rows may be retried; if it happens after status.db update, output rows
        # already exist and resume will skip them.
        with self.lock:
            self._append_rows_locked("success", result.success_rows, OUTPUT_FIELDNAMES)
            self._append_rows_locked("low_attribute", result.low_attribute_rows, OUTPUT_FIELDNAMES)
            self._append_rows_locked("error", result.error_rows, ERROR_FIELDNAMES)
            if result.outcome == BatchOutcome.SERVER_FAILED_OOM:
                self._append_rows_locked("server_failed_oom", result.server_failed_rows, SERVER_FAILED_FIELDNAMES)
            else:
                self._append_rows_locked("server_failed", result.server_failed_rows, SERVER_FAILED_FIELDNAMES)
            if self.status_store is not None:
                self.status_store.upsert_status_rows(result.status_rows)
            self._append_rows_locked("master_status", result.status_rows, STATUS_FIELDNAMES)
            self._append_rows_locked("metrics", [result.metric_row], METRIC_FIELDNAMES)

    def write_oom_rows(self, rows: List[InputRow], batch_id: int, error: str, attempts: int) -> None:
        failed_rows = []
        status_rows = []
        now = utc_now_iso()
        for row in rows:
            failed_rows.append(
                {
                    "row_id": row.row_id,
                    "record_uuid": row.record_uuid,
                    "batch_id": batch_id,
                    "hs_code": row.hs_code,
                    "product_description": row.product_description,
                    "error_type": "server_failed_oom",
                    "error": error,
                }
            )
            status_rows.append(
                {
                    "row_id": row.row_id,
                    "record_uuid": row.record_uuid,
                    "batch_id": batch_id,
                    "hs_code": row.hs_code,
                    "product_description": row.product_description,
                    "status": FinalStatus.SERVER_FAILED_OOM.value,
                    "output_file": "server_failed_oom_output.csv",
                    "error_type": "server_failed_oom",
                    "attempt_count": attempts,
                    "updated_at_utc": now,
                }
            )
        with self.lock:
            self._append_rows_locked("server_failed_oom", failed_rows, SERVER_FAILED_FIELDNAMES)
            if self.status_store is not None:
                self.status_store.upsert_status_rows(status_rows)
            self._append_rows_locked("master_status", status_rows, STATUS_FIELDNAMES)


