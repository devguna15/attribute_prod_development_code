def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def get_domain(hs_code: str) -> str:
    try:
        hs_int = int(str(hs_code).strip().zfill(4)[:2])
        for k, v in HS_MAPPING.items():
            if "-" in k:
                lo, hi = map(int, k.split("-"))
                if lo <= hs_int <= hi:
                    return v
            elif int(k) == hs_int:
                return v
    except Exception:
        pass
    return "General Trade Goods"


def normalize_text(value) -> str:
    if pd.isna(value):
        return ""
    text = str(value).strip()
    return re.sub(r"\s+", " ", text)


def detect_columns(df: pd.DataFrame) -> tuple[str, str]:
    cols = list(df.columns)

    if HS_CODE_COLUMN and DESCRIPTION_COLUMN:
        if HS_CODE_COLUMN not in cols or DESCRIPTION_COLUMN not in cols:
            raise ValueError(f"Configured columns not found. Available columns: {cols}")
        return HS_CODE_COLUMN, DESCRIPTION_COLUMN

    normalized = {c.lower().strip(): c for c in cols}

    hs_candidates = [
        "hs_code", "hscode", "hs code", "hs", "itc_hs_code",
        "hsn", "hsn_code", "hsn code"
    ]
    desc_candidates = [
        "product_description", "product description", "description",
        "item_description", "item description", "product_desc",
        "goods_description", "goods description", "product desc"
    ]

    hs_col = next((normalized[c] for c in hs_candidates if c in normalized), None)
    desc_col = next((normalized[c] for c in desc_candidates if c in normalized), None)

    if hs_col and desc_col:
        return hs_col, desc_col

    hs_col = None
    desc_col = None
    for c in cols:
        lc = c.lower()
        if hs_col is None and ("hs" in lc or "hscode" in lc or "hsn" in lc):
            hs_col = c
        if desc_col is None and ("desc" in lc or "description" in lc or "item" in lc):
            desc_col = c

    if not hs_col or not desc_col:
        raise ValueError(
            "Could not auto-detect HS code and description columns. "
            f"Available columns: {cols}. Set HS_CODE_COLUMN and DESCRIPTION_COLUMN in CONFIG."
        )

    return hs_col, desc_col


def clear_old_files() -> None:
    if not CLEAR_EXISTING_OUTPUTS:
        return
    for path in [OUTPUT_FILE, PENDING_FILE, ERROR_FILE, METRICS_FILE]:
        if os.path.exists(path):
            os.remove(path)


def load_done_keys(*file_paths: str) -> set[tuple[str, str]]:
    done = set()
    for path in file_paths:
        if not os.path.exists(path):
            continue
        with open(path, "r", newline="", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                done.add(
                    (
                        normalize_text(row.get("hs_code", "")),
                        normalize_text(row.get("product_description", "")),
                    )
                )
    return done


def build_batch_prompt(batch_rows: list[dict]) -> str:
    items = []
    for row in batch_rows:
        items.append(
            {
                "row_id": row["row_id"],
                "hs_code": row["hs_code"],
                "domain": get_domain(row["hs_code"]),
                "product_description": row["product_description"],
            }
        )
    return PROMPT_TEMPLATE.format(
        items_json=json.dumps({"items": items}, ensure_ascii=False)
    )


CLIENT = OpenAI(base_url=BASE_URL, api_key=API_KEY)

def get_client() -> OpenAI:
    return CLIENT


def clean_json_text(text: str) -> str:
    text = str(text).strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*", "", text, flags=re.IGNORECASE)
        text = re.sub(r"\s*```$", "", text)
    return text.strip()


def extract_json_object(text: str) -> dict:
    cleaned = clean_json_text(text)
    try:
        parsed = json.loads(cleaned)
        if isinstance(parsed, dict):
            return parsed
    except Exception:
        pass

    start = cleaned.find("{")
    end = cleaned.rfind("}")
    if start == -1 or end == -1 or end <= start:
        raise ValueError("No JSON object found in model output")

    parsed = json.loads(cleaned[start:end + 1])
    if not isinstance(parsed, dict):
        raise ValueError("Parsed output is not a JSON object")
    return parsed


def normalize_product_type(value) -> str:
    if isinstance(value, list):
        value = ", ".join(str(x) for x in value)
    return normalize_text(value)


def normalize_attributes(value) -> dict:
    if isinstance(value, dict):
        return value
    return {}


def normalize_products_list(value) -> list[dict]:
    if isinstance(value, list):
        return [x for x in value if isinstance(x, dict)]
    return []


def attribute_count_for_result(product_type: str, attributes_obj: dict) -> int:
    if not product_type:
        return 0

    if attributes_obj.get("nested") is True:
        products = attributes_obj.get("products", [])
        count = 0
        if isinstance(products, list):
            for product in products:
                if isinstance(product, dict):
                    for key in product.keys():
                        if key != "Product Type":
                            count += 1
        return count

    count = 0
    for key in attributes_obj.keys():
        if key != "nested":
            count += 1
    return count


def parse_prometheus_metrics(text: str) -> dict:
    metrics = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        try:
            metric_part, value_part = line.rsplit(" ", 1)
            metric_name = metric_part.split("{", 1)[0].strip()
            value = float(value_part.strip())
            metrics[metric_name] = metrics.get(metric_name, 0.0) + value
        except Exception:
            continue
    return metrics


def get_metric(metrics: dict, names: list[str], default=0.0):
    for name in names:
        if name in metrics:
            return metrics[name]
    return default


def get_vllm_metrics_snapshot() -> dict:
    try:
        response = requests.get(VLLM_METRICS_URL, timeout=5)
        if response.status_code != 200:
            return {}

        metrics = parse_prometheus_metrics(response.text)

        prefix_queries = get_metric(
            metrics,
            ["vllm:prefix_cache_queries_total", "vllm:prefix_cache_queries"],
            0.0,
        )
        prefix_hits = get_metric(
            metrics,
            ["vllm:prefix_cache_hits_total", "vllm:prefix_cache_hits"],
            0.0,
        )
        kv_cache_usage = get_metric(
            metrics,
            ["vllm:kv_cache_usage_perc", "vllm:gpu_cache_usage_perc"],
            0.0,
        )
        running_requests = get_metric(
            metrics,
            ["vllm:num_requests_running"],
            0.0,
        )
        waiting_requests = get_metric(
            metrics,
            ["vllm:num_requests_waiting"],
            0.0,
        )

        prefix_misses = prefix_queries - prefix_hits
        if prefix_misses < 0:
            prefix_misses = 0.0

        return {
            "prefix_queries": prefix_queries,
            "prefix_hits": prefix_hits,
            "prefix_misses": prefix_misses,
            "kv_cache_usage": kv_cache_usage,
            "running_requests": running_requests,
            "waiting_requests": waiting_requests,
        }
    except Exception:
        return {}


def build_vllm_metrics_delta(before: dict, after: dict) -> dict:
    prefix_queries_delta = after.get("prefix_queries", 0.0) - before.get("prefix_queries", 0.0)
    prefix_hits_delta = after.get("prefix_hits", 0.0) - before.get("prefix_hits", 0.0)
    prefix_misses_delta = after.get("prefix_misses", 0.0) - before.get("prefix_misses", 0.0)

    if prefix_misses_delta < 0:
        prefix_misses_delta = ""

    if prefix_queries_delta > 0:
        prefix_hit_rate_delta = round(prefix_hits_delta / prefix_queries_delta, 4)
    else:
        prefix_hit_rate_delta = ""

    return {
        "prefix_queries_delta": prefix_queries_delta,
        "prefix_hits_delta": prefix_hits_delta,
        "prefix_misses_delta": prefix_misses_delta,
        "prefix_hit_rate_delta": prefix_hit_rate_delta,
        "kv_cache_usage_before": before.get("kv_cache_usage", ""),
        "kv_cache_usage_after": after.get("kv_cache_usage", ""),
        "running_requests_before": before.get("running_requests", ""),
        "running_requests_after": after.get("running_requests", ""),
        "waiting_requests_before": before.get("waiting_requests", ""),
        "waiting_requests_after": after.get("waiting_requests", ""),
    }


