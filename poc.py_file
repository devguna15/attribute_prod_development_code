def append_csv(file_path: str, rows: list[dict], fieldnames: list[str]) -> None:
    if not rows:
        return
    file_exists = os.path.exists(file_path) and os.path.getsize(file_path) > 0
    with open(file_path, "a", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        if not file_exists:
            writer.writeheader()
        for row in rows:
            writer.writerow(row)
        f.flush()
        os.fsync(f.fileno())


# ============================================================
# MODEL CALL
# ============================================================

def call_model_batch(batch_id: int, batch_rows: list[dict]) -> tuple[list[dict], list[dict], list[dict], dict]:
    client = get_client()
    prompt = build_batch_prompt(batch_rows)

    last_error = ""
    last_content = ""
    row_ids = [str(row["row_id"]) for row in batch_rows]

    for attempt in range(1, MAX_RETRIES + 1):
        request_start_perf = time.perf_counter()
        start_ts = utc_now_iso()
        vllm_before = get_vllm_metrics_snapshot()

        try:
            response = client.chat.completions.create(
                model=MODEL_NAME,
                temperature=0,
                max_tokens=MAX_TOKENS,
                response_format={"type": "json_object"},
                messages=[
                    {"role": "system", "content": SYSTEM_PROMPT},
                    {"role": "user", "content": prompt},
                ],
            )

            end_ts = utc_now_iso()
            vllm_after = get_vllm_metrics_snapshot()
            request_duration_sec = time.perf_counter() - request_start_perf
            vllm_delta = build_vllm_metrics_delta(vllm_before, vllm_after)

            content = response.choices[0].message.content or "{}"
            last_content = content

            parsed = extract_json_object(content)
            results = parsed.get("results")

            if not isinstance(results, list):
                raise ValueError("Model output does not contain results array")

            results_by_row_id = {}
            for item in results:
                if not isinstance(item, dict):
                    continue
                row_id = item.get("row_id")
                try:
                    row_id = int(row_id)
                except Exception:
                    continue
                results_by_row_id[row_id] = item

            output_rows = []
            pending_rows = []
            error_rows = []

            for row in batch_rows:
                row_id = row["row_id"]
                result_item = results_by_row_id.get(row_id)

                if not result_item:
                    error_rows.append(
                        {
                            "batch_id": batch_id,
                            "row_id": row_id,
                            "hs_code": row["hs_code"],
                            "product_description": row["product_description"],
                            "error": "Missing result for row_id",
                            "raw_model_output": last_content,
                        }
                    )
                    continue

                nested = result_item.get("nested", False)

                if nested is True:
                    products = normalize_products_list(result_item.get("products", []))
                    score = result_item.get("canonical_similarity_score", "")
                    try:
                        score = float(score)
                    except Exception:
                        score = ""

                    product_type = "NESTED"
                    attributes_obj = {
                        "nested": True,
                        "canonical_similarity_score": score,
                        "products": products,
                    }
                else:
                    product_type = normalize_product_type(result_item.get("Product Type", ""))
                    attributes = normalize_attributes(result_item.get("Attributes", {}))
                    attributes_obj = {
                        "nested": False,
                        **attributes,
                    }

                row_out = {
                    "hs_code": row["hs_code"],
                    "product_description": row["product_description"],
                    "product_type": product_type,
                    "attributes": json.dumps(attributes_obj, ensure_ascii=False),
                }

                attr_len = attribute_count_for_result(product_type, attributes_obj)

                if attr_len < 2:
                    pending_rows.append(row_out)
                else:
                    output_rows.append(row_out)

            usage = getattr(response, "usage", None)
            metric_row = {
                "batch_id": batch_id,
                "rows_in_batch": len(batch_rows),
                "row_ids": ";".join(row_ids),
                "status": "success" if not error_rows else "partial_error",
                "attempt": attempt,
                "error": "" if not error_rows else f"{len(error_rows)} rows missing/invalid",
                "start_ts_utc": start_ts,
                "end_ts_utc": end_ts,
                "request_duration_sec": round(request_duration_sec, 4),
                "rows_per_sec": round(len(batch_rows) / request_duration_sec, 4) if request_duration_sec > 0 else "",
                "prompt_tokens_api": getattr(usage, "prompt_tokens", "") if usage else "",
                "completion_tokens_api": getattr(usage, "completion_tokens", "") if usage else "",
                "total_tokens_api": getattr(usage, "total_tokens", "") if usage else "",
                "prefix_queries_delta": vllm_delta.get("prefix_queries_delta", ""),
                "prefix_hits_delta": vllm_delta.get("prefix_hits_delta", ""),
                "prefix_misses_delta": vllm_delta.get("prefix_misses_delta", ""),
                "prefix_hit_rate_delta": vllm_delta.get("prefix_hit_rate_delta", ""),
                "kv_cache_usage_before": vllm_delta.get("kv_cache_usage_before", ""),
                "kv_cache_usage_after": vllm_delta.get("kv_cache_usage_after", ""),
                "running_requests_before": vllm_delta.get("running_requests_before", ""),
                "running_requests_after": vllm_delta.get("running_requests_after", ""),
                "waiting_requests_before": vllm_delta.get("waiting_requests_before", ""),
                "waiting_requests_after": vllm_delta.get("waiting_requests_after", ""),
            }

            return output_rows, pending_rows, error_rows, metric_row

        except Exception as exc:
            last_error = str(exc)
            if attempt < MAX_RETRIES:
                time.sleep(RETRY_SLEEP_SECONDS)

    metric_row = {
        "batch_id": batch_id,
        "rows_in_batch": len(batch_rows),
        "row_ids": ";".join(row_ids),
        "status": "error",
        "attempt": MAX_RETRIES,
        "error": last_error,
        "start_ts_utc": "",
        "end_ts_utc": "",
        "request_duration_sec": "",
        "rows_per_sec": "",
        "prompt_tokens_api": "",
        "completion_tokens_api": "",
        "total_tokens_api": "",
        "prefix_queries_delta": "",
        "prefix_hits_delta": "",
        "prefix_misses_delta": "",
        "prefix_hit_rate_delta": "",
        "kv_cache_usage_before": "",
        "kv_cache_usage_after": "",
        "running_requests_before": "",
        "running_requests_after": "",
        "waiting_requests_before": "",
        "waiting_requests_after": "",
    }

    error_rows = []
    for row in batch_rows:
        error_rows.append(
            {
                "batch_id": batch_id,
                "row_id": row["row_id"],
                "hs_code": row["hs_code"],
                "product_description": row["product_description"],
                "error": last_error,
                "raw_model_output": last_content,
            }
        )

    return [], [], error_rows, metric_row


# ============================================================
# MAIN
# ============================================================

def main() -> None:
    if not os.path.exists(INPUT_FILE):
        raise FileNotFoundError(
            f"Input file '{INPUT_FILE}' not found in current directory: {os.getcwd()}"
        )

    clear_old_files()

    print("========== ATTRIBUTE PRODUCTION RUN START ==========")
    print(f"Model: {MODEL_NAME}")
    print(f"Input file: {INPUT_FILE}")
    print(f"Output file: {OUTPUT_FILE}")
    print(f"Pending file: {PENDING_FILE}")
    print(f"Error file: {ERROR_FILE}")
    print(f"Metrics file: {METRICS_FILE}")
    print(f"Batch size: {BATCH_SIZE}")
    print(f"Max workers: {MAX_WORKERS}")
    print("===================================================")

    df = pd.read_csv(INPUT_FILE)
    hs_col, desc_col = detect_columns(df)

    print(f"Detected HS code column: {hs_col}")
    print(f"Detected description column: {desc_col}")

    done_keys = load_done_keys(OUTPUT_FILE, PENDING_FILE, ERROR_FILE)
    print(f"Already completed rows found: {len(done_keys)}")

    selected_rows = []
    for _, row in df.iterrows():
        hs_code = normalize_text(row[hs_col])
        product_description = normalize_text(row[desc_col])

        if not product_description:
            continue

        selected_rows.append(
            {
                "row_id": len(selected_rows) + 1,
                "hs_code": hs_code,
                "product_description": product_description,
            }
        )

        if MAX_RECORDS is not None and len(selected_rows) >= MAX_RECORDS:
            break

    pending_input_rows = []
    for row in selected_rows:
        key = (row["hs_code"], row["product_description"])
        if key not in done_keys:
            pending_input_rows.append(row)

    print(f"Rows selected: {len(selected_rows)}")
    print(f"Rows pending after resume check: {len(pending_input_rows)}")

    if not pending_input_rows:
        print("Nothing to process. All rows already handled.")
        return

    batches = []
    for i in range(0, len(pending_input_rows), BATCH_SIZE):
        batch_rows = pending_input_rows[i:i + BATCH_SIZE]
        batch_id = len(batches) + 1
        batches.append((batch_id, batch_rows))

    print(f"Total prompt batches: {len(batches)}")

    total_output = 0
    total_pending = 0
    total_errors = 0

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
        futures = {
            executor.submit(call_model_batch, batch_id, batch_rows): (batch_id, batch_rows)
            for batch_id, batch_rows in batches
        }

        for future in as_completed(futures):
            batch_id, batch_rows = futures[future]

            try:
                output_rows, pending_rows, error_rows, metric_row = future.result()
            except Exception as exc:
                output_rows = []
                pending_rows = []
                error_rows = []
                for row in batch_rows:
                    error_rows.append(
                        {
                            "batch_id": batch_id,
                            "row_id": row["row_id"],
                            "hs_code": row["hs_code"],
                            "product_description": row["product_description"],
                            "error": str(exc),
                            "raw_model_output": "",
                        }
                    )
                metric_row = {
                    "batch_id": batch_id,
                    "rows_in_batch": len(batch_rows),
                    "row_ids": ";".join(str(row["row_id"]) for row in batch_rows),
                    "status": "error",
                    "attempt": MAX_RETRIES,
                    "error": str(exc),
                    "start_ts_utc": "",
                    "end_ts_utc": "",
                    "request_duration_sec": "",
                    "rows_per_sec": "",
                    "prompt_tokens_api": "",
                    "completion_tokens_api": "",
                    "total_tokens_api": "",
                    "prefix_queries_delta": "",
                    "prefix_hits_delta": "",
                    "prefix_misses_delta": "",
                    "prefix_hit_rate_delta": "",
                    "kv_cache_usage_before": "",
                    "kv_cache_usage_after": "",
                    "running_requests_before": "",
                    "running_requests_after": "",
                    "waiting_requests_before": "",
                    "waiting_requests_after": "",
                }

            append_csv(OUTPUT_FILE, output_rows, OUTPUT_FIELDNAMES)
            append_csv(PENDING_FILE, pending_rows, OUTPUT_FIELDNAMES)
            append_csv(ERROR_FILE, error_rows, ERROR_FIELDNAMES)
            append_csv(METRICS_FILE, [metric_row], METRIC_FIELDNAMES)

            total_output += len(output_rows)
            total_pending += len(pending_rows)
            total_errors += len(error_rows)

            print(
                f"Completed batch {batch_id}/{len(batches)} | "
                f"output={len(output_rows)} | pending={len(pending_rows)} | errors={len(error_rows)}"
            )

    print("\n========== ATTRIBUTE PRODUCTION RUN COMPLETE ==========")
    print(f"Successful output rows: {total_output}")
    print(f"Pending rows (<2 attributes): {total_pending}")
    print(f"Error rows: {total_errors}")
    print(f"Output CSV: {OUTPUT_FILE}")
    print(f"Pending CSV: {PENDING_FILE}")
    print(f"Error CSV: {ERROR_FILE}")
    print(f"Metrics CSV: {METRICS_FILE}")
    print("=======================================================")


if __name__ == "__main__":
    main()
